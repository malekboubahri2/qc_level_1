{
	admin off
}

# TLS is terminated by the pmp-edge ingress; this Caddy only serves HTTP
# on :80 inside the Docker network.
:80 {
	encode zstd gzip

	handle /api/* {
		reverse_proxy api:8000 {
			flush_interval -1
		}
	}

	# Serve CA cert with the MIME type Android needs to prompt installation.
	handle /ca.crt {
		root * /srv
		header Content-Type application/x-x509-ca-cert
		file_server
	}

	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
