# Copy to .env and fill in. Never commit .env (it is gitignored).

# ── Web / Caddy ────────────────────────────────────────────────────────────
# Hostname Caddy serves and issues an internal-CA certificate for. Use the
# plant LAN hostname in production (e.g. qc.atelier.local); localhost for a dev box.
SITE_ADDRESS=localhost

# ── API (FastAPI) ──────────────────────────────────────────────────────────
# JWT signing key — generate a long random value, e.g. `openssl rand -hex 32`.
QC_SECRET_KEY=change-me-to-a-long-random-secret-min-32-bytes
# Browser origin allowed for CORS (same host as SITE_ADDRESS over HTTPS).
QC_CORS_ORIGINS=https://localhost
# Escalation timeout in seconds (used from Phase 1).
QC_ALERTE_TIMEOUT_SECONDS=120

# ── Seed admin (created on first boot if no admin exists) ──────────────────
QC_ADMIN_NOM=admin
QC_ADMIN_SECRET=change-me

# Note: QC_DATABASE_URL is set by docker-compose to the on-volume SQLite path.
# For local (non-Docker) runs the app defaults to sqlite:///./qc_level1.db.
