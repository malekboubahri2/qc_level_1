# Normalise line endings to LF in the repo and on checkout, so shell scripts
# (entrypoints, post-create) and configs work identically on Windows hosts and
# inside the Linux dev container.
* text=auto eol=lf

# Binary assets — never normalise.
*.png  binary
*.jpg  binary
*.jpeg binary
*.ico  binary
*.woff  binary
*.woff2 binary

# Generated lockfiles — keep but mark so diffs stay collapsed in reviews.
uv.lock         linguist-generated=true
pnpm-lock.yaml  linguist-generated=true
